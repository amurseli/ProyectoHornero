# Database Configuration
DB_NAME=hornero
DB_USER=hornero
DB_PASSWORD=hornero123

# Redis (compartido con backend - bus de eventos via Redis Streams)
REDIS_HOST=hornero-redis
REDIS_PORT=6379

# Email (SMTP - mismo proveedor que el backend)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@proyectohornero.com

# Mail del administrador que recibe avisos de transferencias pendientes
ADMIN_EMAIL=admin@proyectohornero.com

# JWT Configuration (mismo secret que el backend, para validar tokens del frontend)
JWT_SECRET=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Redis Stream - nombre del stream y grupo de consumidores
NOTIFICATIONS_STREAM_KEY=hornero:notifications:events
NOTIFICATIONS_CONSUMER_GROUP=notifications-group
